# Supabase — anon/publishable key (veilig voor browser)
NEXT_PUBLIC_SUPABASE_URL=https://jouw-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJ...

# Supabase — service role key (NOOIT in NEXT_PUBLIC_, alleen server-side)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# FastAPI backend URL (in productie: je Vercel backend URL)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Shared secret met FastAPI (optioneel, aanbevolen in productie)
# FASTAPI_INTERNAL_TOKEN=willekeurige-lange-string
